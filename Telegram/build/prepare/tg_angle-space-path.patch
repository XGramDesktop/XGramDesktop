+def _windows_short_path(path):
+    """Return a space-free Win32 path when the build root contains spaces."""
+    if os.name != 'nt':
+        return path
+    import ctypes
+    path = os.path.abspath(path)
+    buffer = ctypes.create_unicode_buffer(32768)
+    result = ctypes.windll.kernel32.GetShortPathNameW(
+        path, buffer, len(buffer))
+    return buffer.value if result else path
+
